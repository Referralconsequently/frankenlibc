{
  "schema_version": 1,
  "bead": "bd-4rl",
  "description": "Closure evidence requirements for critique beads. Every critique bead closed after the gate is established must satisfy these evidence requirements.",
  "evidence_requirements": {
    "matrix_entry": {
      "required": true,
      "description": "Bead must have an entry in tests/conformance/verification_matrix.json"
    },
    "test_commands": {
      "required": true,
      "description": "Row must have at least one non-empty test command in unit_cmds or e2e_cmds",
      "fields": ["row.unit_cmds", "row.e2e_cmds"]
    },
    "artifact_references": {
      "required": true,
      "description": "Row must have at least one artifact path or log schema ref",
      "fields": ["row.artifact_paths", "row.log_schema_refs"]
    },
    "coverage_not_missing": {
      "required": true,
      "description": "coverage_summary.overall must be 'partial' or 'complete', not 'missing'",
      "valid_values": ["partial", "complete"]
    },
    "close_blockers_empty": {
      "required": true,
      "description": "row.close_blockers must be empty (all obligations met)"
    }
  },
